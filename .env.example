# =====================================================================
# Variables de entorno del proyecto Angie_presentacion
# =====================================================================
# Copia este archivo a `.env` para desarrollo local:
#     cp .env.example .env   (Linux/macOS)
#     copy .env.example .env (Windows)
#
# En Railway NO subas el .env. En su lugar, define cada variable
# en Project Settings -> Variables.
# =====================================================================


# ----- Django ---------------------------------------------------------

# Cadena aleatoria larga (>=50 chars). En Railway puedes generar una con:
#   python -c "import secrets; print(secrets.token_urlsafe(60))"
SECRET_KEY=cambia-esto-por-una-cadena-aleatoria-larga

# True solo en desarrollo. En Railway pon False.
DEBUG=True

# Hosts permitidos separados por coma. Para Railway no es estrictamente
# necesario porque settings.py ya añade *.up.railway.app automáticamente,
# pero puedes añadir un dominio personalizado aquí.
ALLOWED_HOSTS=localhost,127.0.0.1

# Origins permitidos para CSRF (deben incluir el esquema https://).
# settings.py ya añade *.up.railway.app, así que solo agrega aquí
# tu dominio personalizado si lo configuras.
CSRF_TRUSTED_ORIGINS=

# Segmento de URL del proyecto "Denuncia Verde" (misma ruta que /proyecto-ods16/).
# En Railway: https://<subdominio>.up.railway.app/<PROYECTO_RSOCIAL_URL_PATH>/
# PROYECTO_RSOCIAL_URL_PATH=denuncia-verde

# Si quieres forzar redirección HTTP -> HTTPS en producción.
SECURE_SSL_REDIRECT=False


# ----- Base de datos --------------------------------------------------

# En Railway añade el servicio PostgreSQL y enlaza la variable
# DATABASE_URL automáticamente. En local, deja esta variable vacía y
# se usará SQLite (db.sqlite3).
# Ejemplo: postgres://user:password@host:5432/dbname
DATABASE_URL=


# ----- Email (SMTP, opcional) ----------------------------------------

EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=
